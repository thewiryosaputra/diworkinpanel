# Copy this file to installer/config.env and adjust the values before running.
# Lines starting with # are ignored.

MODE=fresh
DOMAIN=diworkin.com
PANEL_HOST=panel.diworkin.com
EMAIL_HOST=email.diworkin.com
WWW_HOST=www.diworkin.com
MAIL_HOST=mail.diworkin.com
WEBMAIL_HOST=webmail.diworkin.com
PUBLIC_IP=141.94.121.242

# License (optional)
# Jika diisi, installer akan memverifikasi lisensi ke panel sebelum melanjutkan install.
# Contoh: LICENSE_API_URL=https://panel.diworkin.com/api/licenses/verify
LICENSE_API_URL=
LICENSE_KEY=
LICENSE_DOMAIN=
LICENSE_PRODUCT=
LICENSE_TYPE=hosting

# Optional overrides
# NEXT_PUBLIC_PANEL_URL=https://panel.diworkin.com
# NEXT_PUBLIC_API_BASE_URL=https://panel.diworkin.com/api
