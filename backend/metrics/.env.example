# Diworkin panel runtime environment.
# Copy this to a protected file on the server and do not commit the real values.

DIWORKIN_PANEL_ADDR=127.0.0.1:8080
DIWORKIN_PANEL_DSN=
DIWORKIN_SESSION_SECRET=
DIWORKIN_COOKIE_SECURE=true
DIWORKIN_COOKIE_DOMAIN=.diworkin.com
DIWORKIN_PANEL_PUBLIC_URL=https://panel.diworkin.com
DIWORKIN_MAIL_COOKIE_DOMAIN=.diworkin.com
DIWORKIN_MAIL_PUBLIC_URL=https://email.diworkin.com
DIWORKIN_PUBLIC_IP=
DIWORKIN_SITES_ROOT=/var/www/diworkin-sites
DIWORKIN_BACKUP_ROOT=/var/backups/diworkin-panel
DIWORKIN_MAIL_DSN=
DIWORKIN_SMTP_HOST=127.0.0.1
DIWORKIN_SMTP_PORT=25
DIWORKIN_SMTP_USERNAME=
DIWORKIN_SMTP_PASSWORD=
DIWORKIN_SMTP_FROM="Diworkin Panel <no-reply@diworkin.com>"
DIWORKIN_BOOTSTRAP_EMAIL=admin@diworkin.com
DIWORKIN_BOOTSTRAP_PASSWORD=
DIWORKIN_BOOTSTRAP_NAME="Diworkin Admin"
DIWORKIN_BOOTSTRAP_COMPANY=Diworkin

